{
  "name": "anvil",
  "displayName": "Anvil",
  "description": "Capture todos in your repo and sync them to Azure DevOps, GitHub, or GitLab. Delegate work to Claude Code or Copilot agents.",
  "version": "0.3.4",
  "publisher": "moizmh",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:anvil.todoTree",
    "workspaceContains:.todos/todos.json",
    "workspaceContains:.ado/todos.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anvil",
          "title": "Anvil",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "anvil": [
        {
          "id": "anvil.todoTree",
          "name": "Todos"
        }
      ]
    },
    "commands": [
      { "command": "anvil.add", "title": "Anvil: Add Todo", "icon": "$(add)" },
      { "command": "anvil.sync", "title": "Anvil: Sync", "icon": "$(cloud-upload)" },
      { "command": "anvil.refresh", "title": "Anvil: Refresh", "icon": "$(refresh)" },
      { "command": "anvil.edit", "title": "Edit", "icon": "$(edit)" },
      { "command": "anvil.delete", "title": "Delete", "icon": "$(trash)" },
      { "command": "anvil.runAgent", "title": "Run with Agent…", "icon": "$(play)" },
      { "command": "anvil.openMetrics", "title": "Anvil: Open Metrics Dashboard", "icon": "$(graph)" },
      { "command": "anvil.configure", "title": "Anvil: Configure Provider" }
    ],
    "menus": {
      "view/title": [
        { "command": "anvil.add", "when": "view == anvil.todoTree", "group": "navigation@1" },
        { "command": "anvil.sync", "when": "view == anvil.todoTree", "group": "navigation@2" },
        { "command": "anvil.openMetrics", "when": "view == anvil.todoTree", "group": "navigation@3" },
        { "command": "anvil.refresh", "when": "view == anvil.todoTree", "group": "navigation@4" }
      ],
      "view/item/context": [
        { "command": "anvil.runAgent", "when": "view == anvil.todoTree && viewItem == todo", "group": "inline@1" },
        { "command": "anvil.delete", "when": "view == anvil.todoTree && viewItem == todo", "group": "inline@2" }
      ]
    },
    "configuration": {
      "title": "Anvil",
      "properties": {
        "anvil.defaultAgent": {
          "type": "string",
          "enum": ["claude-code", "copilot", "open-issue"],
          "default": "claude-code",
          "description": "Default agent to run when 'Run with Agent' has no explicit choice."
        },
        "anvil.claudeCodeCommand": {
          "type": "string",
          "default": "claude",
          "description": "Command used to invoke Claude Code CLI."
        },
        "anvil.claudeCode.model": {
          "type": "string",
          "enum": ["sonnet", "opus", "haiku"],
          "default": "sonnet",
          "description": "Default model for Claude Code agent runs."
        },
        "anvil.claudeCode.reasoning": {
          "type": "string",
          "enum": ["none", "think", "think-hard", "ultrathink"],
          "default": "none",
          "description": "Default reasoning intensity hint appended to Claude Code prompts."
        },
        "anvil.claudeCode.approvals": {
          "type": "string",
          "enum": ["default", "acceptEdits", "plan", "bypassPermissions"],
          "default": "default",
          "description": "Default --permission-mode for Claude Code."
        },
        "anvil.copilot.mode": {
          "type": "string",
          "enum": ["agent", "edit", "ask"],
          "default": "agent",
          "description": "Default Copilot Chat mode slash-command."
        },
        "anvil.copilot.model": {
          "type": "string",
          "default": "",
          "description": "Optional model hint included in the Copilot prompt."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "@gitbeaker/rest": "^40.5.1",
    "@octokit/rest": "^21.0.2",
    "azure-devops-node-api": "^14.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.4.5"
  }
}
