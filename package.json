{
  "name": "djinn",
  "displayName": "Djinn",
  "description": "Capture todos in your repo and sync them to Azure DevOps, GitHub, or GitLab. Delegate work to Claude Code or Copilot agents.",
  "version": "0.4.12",
  "publisher": "moizmh",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:djinn.todoTree",
    "workspaceContains:.todos/todos.json",
    "workspaceContains:.ado/todos.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "djinn",
          "title": "Djinn",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "djinn": [
        {
          "id": "djinn.todoEditor",
          "name": "Djinn",
          "type": "webview",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      { "command": "djinn.add", "title": "Djinn: New Todo", "icon": "$(add)" },
      { "command": "djinn.sync", "title": "Djinn: Sync", "icon": "$(cloud-upload)" },
      { "command": "djinn.refresh", "title": "Djinn: Refresh", "icon": "$(refresh)" },
      { "command": "djinn.edit", "title": "Edit", "icon": "$(edit)" },
      { "command": "djinn.delete", "title": "Delete", "icon": "$(trash)" },
      { "command": "djinn.runAgent", "title": "Run with Agent…", "icon": "$(play)" },
      { "command": "djinn.openMetrics", "title": "Djinn: Open Metrics Dashboard", "icon": "$(graph)" },
      { "command": "djinn.configure", "title": "Djinn: Configure Provider" }
    ],
    "menus": {
      "view/title": [
        { "command": "djinn.add", "when": "view == djinn.todoEditor", "group": "navigation@1" },
        { "command": "djinn.sync", "when": "view == djinn.todoEditor", "group": "navigation@2" },
        { "command": "djinn.openMetrics", "when": "view == djinn.todoEditor", "group": "navigation@3" },
        { "command": "djinn.refresh", "when": "view == djinn.todoEditor", "group": "navigation@4" }
      ]
    },
    "configuration": {
      "title": "Djinn",
      "properties": {
        "djinn.defaultAgent": {
          "type": "string",
          "enum": ["copilot", "claude-code", "open-issue"],
          "default": "copilot",
          "description": "Default provider to run when 'Run with Agent' has no explicit choice."
        },
        "djinn.claudeCodeCommand": {
          "type": "string",
          "default": "claude",
          "description": "Command used to invoke Claude Code CLI."
        },
        "djinn.claudeCode.model": {
          "type": "string",
          "enum": ["auto", "claude-sonnet-4-6", "claude-opus-4-7", "claude-haiku-4-5"],
          "default": "auto",
          "description": "Default model for Claude Code agent runs."
        },
        "djinn.claudeCode.reasoning": {
          "type": "string",
          "enum": ["none", "think", "think-hard", "ultrathink"],
          "default": "none",
          "description": "Default reasoning intensity hint appended to Claude Code prompts."
        },
        "djinn.claudeCode.approvals": {
          "type": "string",
          "enum": ["default", "acceptEdits", "plan", "bypassPermissions"],
          "default": "default",
          "description": "Default --permission-mode for Claude Code."
        },
        "djinn.copilot.mode": {
          "type": "string",
          "enum": ["agent", "ask", "plan"],
          "default": "agent",
          "description": "Default Copilot Chat mode slash-command."
        },
        "djinn.copilot.model": {
          "type": "string",
          "default": "",
          "description": "Optional model hint included in the Copilot prompt."
        },
        "djinn.copilot.approvals": {
          "type": "string",
          "enum": ["default", "bypass", "autopilot"],
          "default": "default",
          "description": "Default approvals mode for Copilot tool calls."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "preview": "node scripts/preview-server.mjs",
    "package": "vsce package"
  },
  "dependencies": {
    "@gitbeaker/rest": "^40.5.1",
    "@octokit/rest": "^21.0.2",
    "azure-devops-node-api": "^14.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.4.5"
  }
}
